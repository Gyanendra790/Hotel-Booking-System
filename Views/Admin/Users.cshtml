@model IEnumerable<UserListViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <h4><i class="bi bi-person-gear me-2 text-primary"></i>User Management</h4>
    <a asp-action="CreateUser" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Create User</a>
</div>

<div class="section-card">
    <div class="section-card-body">
        <table class="table-hotel w-100">
            <thead>
                <tr>
                    <th>Full Name</th><th>Email</th><th>Role</th>
                    <th>Status</th><th>Created By</th><th>Created At</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div style="width:34px;height:34px;background:var(--sidebar-active-bg);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--primary);flex-shrink:0">
                                <i class="bi bi-person"></i>
                            </div>
                            <span class="fw-600">@u.FullName</span>
                        </div>
                    </td>
                    <td class="small">@u.Email</td>
                    <td>
                        @{
                            var roleBadge = u.Role switch {
                                "Admin" => "badge-suite",
                                "Manager" => "badge-deluxe",
                                _ => "badge-standard"
                            };
                        }
                        <span class="badge-status @roleBadge">@u.Role</span>
                    </td>
                    <td>
                        @if (u.IsActive)
                        {
                            <span class="badge-status badge-available"><i class="bi bi-check-circle me-1"></i>Active</span>
                        }
                        else
                        {
                            <span class="badge-status badge-cancelled"><i class="bi bi-x-circle me-1"></i>Disabled</span>
                        }
                    </td>
                    <td class="small text-muted">@(u.CreatedBy ?? "—")</td>
                    <td class="small text-muted">@u.CreatedAt.ToString("MM/dd/yyyy")</td>
                    <td>
                        <a asp-action="EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary btn-icon" title="Edit"><i class="bi bi-pencil"></i></a>

                        <form asp-action="ToggleUserStatus" method="post" class="d-inline ms-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success") btn-icon"
                                    title="@(u.IsActive ? "Disable" : "Enable")"
                                    data-confirm="@(u.IsActive ? "Disable" : "Enable") user @u.FullName?">
                                <i class="bi bi-@(u.IsActive ? "toggle-on" : "toggle-off")"></i>
                            </button>
                        </form>

                        <!-- Reset Password Modal Trigger -->
                        <button class="btn btn-sm btn-outline-secondary btn-icon ms-1"
                                title="Reset Password"
                                data-bs-toggle="modal"
                                data-bs-target="#resetModal"
                                data-userid="@u.Id"
                                data-username="@u.FullName">
                            <i class="bi bi-key"></i>
                        </button>

                        <form asp-action="DeleteUser" method="post" class="d-inline ms-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="btn btn-sm btn-outline-danger btn-icon"
                                    title="Delete"
                                    data-confirm="Permanently delete user @u.FullName?">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="no-results"><i class="bi bi-people d-block mb-2"></i>No users found</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h6 class="modal-title"><i class="bi bi-key me-2"></i>Reset Password</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="resetUserId" />
                    <p class="small text-muted">Resetting password for: <strong id="resetUserName"></strong></p>
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" name="newPassword" class="form-control" placeholder="Min 6 chars, upper+lower+digit+special" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-primary">Reset</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('[data-confirm]').forEach(btn => {
            btn.addEventListener('click', e => { if (!confirm(btn.dataset.confirm)) e.preventDefault(); });
        });

        const resetModal = document.getElementById('resetModal');
        if (resetModal) {
            resetModal.addEventListener('show.bs.modal', e => {
                const btn = e.relatedTarget;
                document.getElementById('resetUserId').value = btn.dataset.userid;
                document.getElementById('resetUserName').textContent = btn.dataset.username;
            });
        }
    </script>
}
