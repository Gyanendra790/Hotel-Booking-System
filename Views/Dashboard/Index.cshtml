@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-door-open"></i></div>
            <div class="stat-body">
                <div class="stat-label">Total Rooms</div>
                <div class="stat-value">@Model.TotalRooms</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
            <div class="stat-body">
                <div class="stat-label">Available</div>
                <div class="stat-value">@Model.AvailableRooms</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-person-fill"></i></div>
            <div class="stat-body">
                <div class="stat-label">Occupied</div>
                <div class="stat-value">@Model.OccupiedRooms</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="stat-icon teal"><i class="bi bi-box-arrow-in-right"></i></div>
            <div class="stat-body">
                <div class="stat-label">Check-ins Today</div>
                <div class="stat-value">@Model.TodayCheckIns</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-box-arrow-right"></i></div>
            <div class="stat-body">
                <div class="stat-label">Check-outs Today</div>
                <div class="stat-value">@Model.TodayCheckOuts</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
           <div class="stat-icon purple">₹</div>
            <div class="stat-body">
                <div class="stat-label">Monthly Revenue</div>
                <div class="stat-value" style="font-size:18px">₹@Model.MonthlyRevenue.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<!-- Occupancy + Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h6><i class="bi bi-bar-chart-fill text-primary"></i> Room Occupancy by Type</h6>
            </div>
            <div class="section-card-body p-4">
                @{
                    var totalByType = new Dictionary<string, int>
                    {
                        { "Standard", 2 }, { "Deluxe", 2 }, { "Suite", 2 }
                    };
                }
                @foreach (var item in Model.RoomTypeOccupancy)
                {
                    var total = totalByType.GetValueOrDefault(item.Key, 1);
                    var pct = total > 0 ? (int)((double)item.Value / total * 100) : 0;
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="fw-600 small">@item.Key Rooms</span>
                            <span class="small text-muted">@item.Value / @total occupied (@pct%)</span>
                        </div>
                        <div class="occupancy-bar">
                            <div class="occupancy-fill" style="width:@pct%"></div>
                        </div>
                    </div>
                }

                <hr class="my-3" />
                <div class="row text-center g-2 mt-1">
                    <div class="col-4">
                        <div class="fw-800 fs-4 text-success">@Model.AvailableRooms</div>
                        <div class="small text-muted">Available</div>
                    </div>
                    <div class="col-4">
                        <div class="fw-800 fs-4 text-danger">@Model.OccupiedRooms</div>
                        <div class="small text-muted">Occupied</div>
                    </div>
                    <div class="col-4">
                        <div class="fw-800 fs-4 text-warning">@Model.PendingBookings</div>
                        <div class="small text-muted">Pending</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="section-card h-100">
            <div class="section-card-header">
                <h6><i class="bi bi-lightning-fill text-warning"></i> Quick Actions</h6>
            </div>
            <div class="section-card-body p-3 d-flex flex-column gap-2">
                <a asp-controller="Booking" asp-action="Create" class="btn btn-primary w-100 text-start">
                    <i class="bi bi-plus-circle me-2"></i> New Booking
                </a>
                <a asp-controller="Room" asp-action="Availability" class="btn btn-outline-primary w-100 text-start">
                    <i class="bi bi-search me-2"></i> Check Room Availability
                </a>
                <a asp-controller="Guest" asp-action="Create" class="btn btn-outline-secondary w-100 text-start">
                    <i class="bi bi-person-plus me-2"></i> Add New Guest
                </a>
                <a asp-controller="Invoice" asp-action="Index" class="btn btn-outline-secondary w-100 text-start">
                    <i class="bi bi-receipt me-2"></i> View Invoices
                </a>
                <a asp-controller="Room" asp-action="Index" class="btn btn-outline-secondary w-100 text-start">
                    <i class="bi bi-door-open me-2"></i> Manage Rooms
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Arrivals & Departures -->
<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="section-card">
            <div class="section-card-header">
                <h6><i class="bi bi-box-arrow-in-right text-success"></i> Today's Arrivals</h6>
                <span class="badge bg-success">@Model.TodayArrivals.Count</span>
            </div>
            <div class="section-card-body">
                @if (!Model.TodayArrivals.Any())
                {
                    <div class="no-results py-3"><i class="bi bi-calendar-x"></i><small>No arrivals today</small></div>
                }
                else
                {
                    <table class="table-hotel w-100">
                        <thead><tr><th>Guest</th><th>Room</th><th>Action</th></tr></thead>
                        <tbody>
                        @foreach (var b in Model.TodayArrivals)
                        {
                            <tr>
                                <td>
                                    <div class="fw-600">@b.Guest.FullName</div>
                                    <div class="small text-muted">@b.BookingReference</div>
                                </td>
                                <td><span class="badge-status badge-@b.Room.RoomType.ToString().ToLower()">@b.Room.RoomNumber</span></td>
                                <td>
                                    <form asp-controller="Booking" asp-action="CheckIn" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@b.BookingId" />
                                        <button class="btn btn-success btn-sm">Check In</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="section-card">
            <div class="section-card-header">
                <h6><i class="bi bi-box-arrow-right text-danger"></i> Today's Departures</h6>
                <span class="badge bg-danger">@Model.TodayDepartures.Count</span>
            </div>
            <div class="section-card-body">
                @if (!Model.TodayDepartures.Any())
                {
                    <div class="no-results py-3"><i class="bi bi-calendar-x"></i><small>No departures today</small></div>
                }
                else
                {
                    <table class="table-hotel w-100">
                        <thead><tr><th>Guest</th><th>Room</th><th>Action</th></tr></thead>
                        <tbody>
                        @foreach (var b in Model.TodayDepartures)
                        {
                            <tr>
                                <td>
                                    <div class="fw-600">@b.Guest.FullName</div>
                                    <div class="small text-muted">@b.BookingReference</div>
                                </td>
                                <td><span class="badge-status badge-@b.Room.RoomType.ToString().ToLower()">@b.Room.RoomNumber</span></td>
                                <td>
                                    <form asp-controller="Booking" asp-action="CheckOut" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@b.BookingId" />
                                        <button class="btn btn-warning btn-sm">Check Out</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<!-- Recent Bookings -->
<div class="section-card">
    <div class="section-card-header">
        <h6><i class="bi bi-clock-history text-primary"></i> Recent Bookings</h6>
        <a asp-controller="Booking" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="section-card-body">
        <table class="table-hotel w-100">
            <thead>
                <tr>
                    <th>Ref #</th><th>Guest</th><th>Room</th>
                    <th>Check-in</th><th>Check-out</th><th>Amount</th><th>Status</th><th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var b in Model.RecentBookings)
            {
                <tr>
                    <td><span class="fw-600 text-primary">@b.BookingReference</span></td>
                    <td>@b.Guest.FullName</td>
                    <td>@b.Room.RoomNumber (@b.Room.RoomType)</td>
                    <td>@b.CheckInDate.ToString("MM/dd/yyyy")</td>
                    <td>@b.CheckOutDate.ToString("MM/dd/yyyy")</td>
                    <td class="fw-600">₹@b.TotalAmount.ToString("N2")</td>
                    <td>
                        <span class="badge-status badge-@b.Status.ToString().ToLower().Replace(" ", "")">
                            @b.Status
                        </span>
                    </td>
                    <td>
                        <a asp-controller="Booking" asp-action="Details" asp-route-id="@b.BookingId"
                           class="btn btn-sm btn-outline-primary btn-icon" title="View">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.RecentBookings.Any())
            {
                <tr><td colspan="8" class="no-results"><i class="bi bi-inbox d-block mb-2"></i>No bookings yet</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
