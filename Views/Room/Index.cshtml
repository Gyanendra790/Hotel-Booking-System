@model IEnumerable<Room>
@{
    ViewData["Title"] = "Rooms";
}

<div class="page-header">
    <h4><i class="bi bi-door-open me-2 text-primary"></i>Rooms</h4>
    <div class="page-header-actions">
        <a asp-action="Availability" class="btn btn-outline-primary"><i class="bi bi-search me-1"></i>Check Availability</a>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Add Room</a>
        }
    </div>
</div>

<!-- Legend -->
<div class="d-flex gap-3 mb-3 flex-wrap">
    <span class="badge-status badge-available"><i class="bi bi-circle-fill me-1"></i>Available</span>
    <span class="badge-status badge-occupied"><i class="bi bi-circle-fill me-1"></i>Occupied</span>
    <span class="badge-status badge-maintenance"><i class="bi bi-circle-fill me-1"></i>Maintenance</span>
    <span class="badge-status badge-reserved"><i class="bi bi-circle-fill me-1"></i>Reserved</span>
</div>

<div class="row g-3">
@foreach (var room in Model)
{
    <div class="col-md-6 col-xl-4">
        <div class="room-card">
            <div class="room-card-header">
                <div>
                    <span class="room-number">@room.RoomNumber</span>
                    <div class="text-muted small">Floor @room.Floor</div>
                </div>
                <div class="text-end">
                    <span class="badge-status badge-@room.Status.ToString().ToLower()">@room.Status</span>
                    <div class="mt-1"><span class="badge-status badge-@room.RoomType.ToString().ToLower()">@room.RoomType</span></div>
                </div>
            </div>
            <div class="room-card-body">
                <div class="text-muted small mb-2">@(room.Description ?? "No description")</div>
                <div class="mb-2">
                    @if (room.HasAC) { <span class="room-amenity"><i class="bi bi-wind"></i>AC</span> }
                    @if (room.HasWiFi) { <span class="room-amenity"><i class="bi bi-wifi"></i>WiFi</span> }
                    @if (room.HasTV) { <span class="room-amenity"><i class="bi bi-tv"></i>TV</span> }
                    @if (room.HasMiniBar) { <span class="room-amenity"><i class="bi bi-cup-hot"></i>Mini Bar</span> }
                    <span class="room-amenity"><i class="bi bi-people"></i>Max @room.MaxOccupancy</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="room-price">$@room.PricePerNight.ToString("N0") <span>/ night</span></div>
                    <div class="d-flex gap-1">
                        @if (room.Status == RoomStatus.Available)
                        {
                            <a asp-controller="Booking" asp-action="Create" asp-route-roomId="@room.RoomId"
                               class="btn btn-success btn-sm"><i class="bi bi-plus"></i> Book</a>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a asp-action="Edit" asp-route-id="@room.RoomId" class="btn btn-outline-secondary btn-sm btn-icon"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@room.RoomId" />
                                <button class="btn btn-outline-danger btn-sm btn-icon" data-confirm="Delete Room @room.RoomNumber?"><i class="bi bi-trash"></i></button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@if (!Model.Any())
{
    <div class="col-12 no-results"><i class="bi bi-door-closed d-block mb-2" style="font-size:40px"></i>No rooms found</div>
}
</div>

@section Scripts {
    <script>
        document.querySelectorAll('[data-confirm]').forEach(btn => {
            btn.addEventListener('click', e => { if (!confirm(btn.dataset.confirm)) e.preventDefault(); });
        });
    </script>
}
