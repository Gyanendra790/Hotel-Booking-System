@model Room
@{
    bool isEdit = Model.RoomId > 0;
    ViewData["Title"] = isEdit ? "Edit Room" : "Add Room";
}

<div class="page-header">
    <h4><i class="bi bi-door-open me-2 text-primary"></i>@ViewData["Title"]</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @Html.AntiForgeryToken()
            <div class="form-section">
                <div class="form-section-header"><i class="bi bi-door-open text-primary"></i> Room Details</div>
                <div class="form-section-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="RoomNumber" class="form-label">Room Number</label>
                            <input asp-for="RoomNumber" class="form-control" placeholder="101" />
                            <span asp-validation-for="RoomNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Floor" class="form-label">Floor</label>
                            <input asp-for="Floor" type="number" min="1" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="RoomType" class="form-label">Room Type</label>
                            <select asp-for="RoomType" asp-items="Html.GetEnumSelectList<RoomType>()" class="form-select"></select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label">Status</label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<RoomStatus>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PricePerNight" class="form-label">Price Per Night ($)</label>
                            <input asp-for="PricePerNight" type="number" step="0.01" min="0" class="form-control" />
                            <span asp-validation-for="PricePerNight" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxOccupancy" class="form-label">Max Occupancy</label>
                            <input asp-for="MaxOccupancy" type="number" min="1" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Room description..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Amenities</label>
                            <div class="d-flex flex-wrap gap-4">
                                <div class="form-check">
                                    <input asp-for="HasAC" class="form-check-input" />
                                    <label asp-for="HasAC" class="form-check-label"><i class="bi bi-wind me-1"></i>Air Conditioning</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="HasWiFi" class="form-check-input" />
                                    <label asp-for="HasWiFi" class="form-check-label"><i class="bi bi-wifi me-1"></i>WiFi</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="HasTV" class="form-check-input" />
                                    <label asp-for="HasTV" class="form-check-label"><i class="bi bi-tv me-1"></i>TV</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="HasMiniBar" class="form-check-input" />
                                    <label asp-for="HasMiniBar" class="form-check-label"><i class="bi bi-cup-hot me-1"></i>Mini Bar</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>@(isEdit ? "Save Changes" : "Add Room")</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
