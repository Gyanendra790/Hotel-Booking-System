@model RoomAvailabilityViewModel
@{
    ViewData["Title"] = "Room Availability";
}

<div class="page-header">
    <h4><i class="bi bi-search me-2 text-primary"></i>Check Room Availability</h4>
</div>

<div class="form-section mb-4">
    <div class="form-section-header"><i class="bi bi-funnel text-primary"></i> Search Criteria</div>
    <div class="form-section-body">
        <form method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger small col-12"></div>
            <div class="col-md-3">
                <label asp-for="CheckInDate" class="form-label">Check-in Date</label>
                <input asp-for="CheckInDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label asp-for="CheckOutDate" class="form-label">Check-out Date</label>
                <input asp-for="CheckOutDate" type="date" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="RoomType" class="form-label">Room Type</label>
                <select asp-for="RoomType" asp-items="Html.GetEnumSelectList<RoomType>()" class="form-select">
                    <option value="">All Types</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-2"></i>Check Availability
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.SearchPerformed)
{
    <div class="page-header mb-3">
        <h5 class="m-0">
            Results for @Model.CheckInDate.ToString("MMM dd") – @Model.CheckOutDate.ToString("MMM dd, yyyy")
            (@((Model.CheckOutDate - Model.CheckInDate).Days) nights)
        </h5>
        <span class="badge bg-success fs-6">@Model.AvailableRooms.Count room(s) available</span>
    </div>

    @if (!Model.AvailableRooms.Any())
    {
        <div class="section-card">
            <div class="no-results py-5">
                <i class="bi bi-emoji-frown d-block mb-2" style="font-size:48px"></i>
                <h5>No rooms available for these dates</h5>
                <p class="text-muted">Try different dates or room type.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var room in Model.AvailableRooms)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="room-card">
                        <div class="room-card-header">
                            <div>
                                <span class="room-number">@room.RoomNumber</span>
                                <div class="text-muted small">Floor @room.Floor</div>
                            </div>
                            <div class="text-end">
                                <span class="badge-status badge-available">Available</span>
                                <div class="mt-1"><span class="badge-status badge-@room.RoomType.ToString().ToLower()">@room.RoomType</span></div>
                            </div>
                        </div>
                        <div class="room-card-body">
                            <div class="text-muted small mb-2">@(room.Description ?? "—")</div>
                            <div class="mb-2">
                                @if (room.HasAC) { <span class="room-amenity"><i class="bi bi-wind"></i>AC</span> }
                                @if (room.HasWiFi) { <span class="room-amenity"><i class="bi bi-wifi"></i>WiFi</span> }
                                @if (room.HasTV) { <span class="room-amenity"><i class="bi bi-tv"></i>TV</span> }
                                @if (room.HasMiniBar) { <span class="room-amenity"><i class="bi bi-cup-hot"></i>Mini Bar</span> }
                                <span class="room-amenity"><i class="bi bi-people"></i>Max @room.MaxOccupancy</span>
                            </div>
                            @{
                                int nights = (Model.CheckOutDate - Model.CheckInDate).Days;
                                decimal total = room.PricePerNight * nights;
                            }
                            <div class="fare-summary mt-2 mb-2">
                                <div class="fare-row"><span>@nights night(s) × $@room.PricePerNight</span><span class="fw-600">$@total.ToString("N2")</span></div>
                            </div>
                            <div class="room-price mb-2">$@room.PricePerNight.ToString("N0") <span>/ night</span></div>
                            <a asp-controller="Booking" asp-action="Create"
                               asp-route-roomId="@room.RoomId"
                               class="btn btn-success w-100">
                                <i class="bi bi-calendar-plus me-2"></i>Book This Room
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
