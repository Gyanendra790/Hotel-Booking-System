@model IEnumerable<Booking>
@{
    ViewData["Title"] = "Bookings";
}

<div class="page-header">
    <h4><i class="bi bi-calendar-check me-2 text-primary"></i>All Bookings</h4>
    <div class="page-header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> New Booking
        </a>
    </div>
</div>

<!-- Filters -->
<div class="section-card mb-3">
    <div class="section-card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by ref, guest, room…" />
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in (BookingStatus[])ViewBag.Statuses)
                    {
                        <option value="@s" selected="@(ViewBag.StatusFilter == s.ToString())">@s</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="section-card">
    <div class="section-card-body">
        <table class="table-hotel w-100">
            <thead>
                <tr>
                    <th>Ref #</th><th>Guest</th><th>Room</th>
                    <th>Check-in</th><th>Check-out</th><th>Nights</th>
                    <th>Total</th><th>Status</th><th>Payment</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td><span class="fw-600 text-primary">@b.BookingReference</span></td>
                    <td>
                        <div class="fw-600">@b.Guest.FullName</div>
                        <div class="small text-muted">@b.Guest.Email</div>
                    </td>
                    <td>
                        <div>@b.Room.RoomNumber</div>
                        <span class="badge-status badge-@b.Room.RoomType.ToString().ToLower()">@b.Room.RoomType</span>
                    </td>
                    <td>@b.CheckInDate.ToString("MM/dd/yy")</td>
                    <td>@b.CheckOutDate.ToString("MM/dd/yy")</td>
                    <td class="text-center">@b.NumberOfNights</td>
                    <td class="fw-600">$@b.TotalAmount.ToString("N2")</td>
                    <td>
                        <span class="badge-status badge-@b.Status.ToString().ToLower()">@b.Status</span>
                    </td>
                    <td>
                        <span class="badge-status badge-@b.PaymentStatus.ToString().ToLower()">@b.PaymentStatus</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@b.BookingId" class="btn btn-sm btn-outline-primary btn-icon" title="View"><i class="bi bi-eye"></i></a>
                        @if (b.Status == BookingStatus.Pending || b.Status == BookingStatus.Confirmed)
                        {
                            <a asp-action="Edit" asp-route-id="@b.BookingId" class="btn btn-sm btn-outline-secondary btn-icon ms-1" title="Edit"><i class="bi bi-pencil"></i></a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="10" class="no-results"><i class="bi bi-inbox d-block mb-2"></i>No bookings found</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
