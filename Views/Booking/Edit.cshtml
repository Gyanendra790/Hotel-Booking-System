@model Booking
@{
    ViewData["Title"] = "Edit Booking";
}

<div class="page-header">
    <h4><i class="bi bi-pencil me-2 text-primary"></i>Edit Booking — @Model.BookingReference</h4>
    <a asp-action="Details" asp-route-id="@Model.BookingId" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="BookingId" />
    <input type="hidden" asp-for="BookingReference" />
    <input type="hidden" asp-for="GuestId" />
    <input type="hidden" asp-for="RoomId" />

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="form-section mb-3">
                <div class="form-section-header"><i class="bi bi-calendar3 text-primary"></i> Stay Details</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="CheckInDate" class="form-label">Check-in Date</label>
                            <input asp-for="CheckInDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CheckOutDate" class="form-label">Check-out Date</label>
                            <input asp-for="CheckOutDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NumberOfGuests" class="form-label">Number of Guests</label>
                            <input asp-for="NumberOfGuests" type="number" min="1" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="SpecialRequests" class="form-label">Special Requests</label>
                            <textarea asp-for="SpecialRequests" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section mb-3">
                <div class="form-section-header"><i class="bi bi-cash-coin text-primary"></i> Charges & Payment</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="ExtraCharges" class="form-label">Extra Charges ($)</label>
                            <input asp-for="ExtraCharges" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Discount" class="form-label">Discount ($)</label>
                            <input asp-for="Discount" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="AmountPaid" class="form-label">Amount Paid ($)</label>
                            <input asp-for="AmountPaid" type="number" step="0.01" min="0" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="PaymentStatus" class="form-label">Payment Status</label>
                            <select asp-for="PaymentStatus" asp-items="Html.GetEnumSelectList<PaymentStatus>()" class="form-select"></select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section mb-3">
                <div class="form-section-header"><i class="bi bi-info-circle text-primary"></i> Booking Status & Notes</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label">Booking Status</label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<BookingStatus>()" class="form-select"></select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label">Internal Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="form-section sticky-top" style="top:80px">
                <div class="form-section-header"><i class="bi bi-person-circle text-primary"></i> Guest</div>
                <div class="form-section-body">
                    <div class="fw-600">@Model.Guest?.FullName</div>
                    <div class="text-muted small">@Model.Guest?.Email</div>
                    <hr />
                    <div class="fw-600">Room @Model.Room?.RoomNumber</div>
                    <div class="text-muted small">@Model.Room?.RoomType – $@Model.Room?.PricePerNight/night</div>
                </div>
            </div>
            <div class="mt-3 d-grid gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.BookingId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
