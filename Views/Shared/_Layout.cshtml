<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Grand Palace Hotel</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon"><i class="bi bi-building"></i></div>
                <div class="brand-text">
                    <span class="brand-title">Grand Palace</span>
                    <span class="brand-sub">Hotel Management</span>
                </div>
            </div>

            <div class="sidebar-user">
                <div class="user-avatar"><i class="bi bi-person-circle"></i></div>
                <div class="user-info">
                    <span class="user-name">@User.Identity.Name?.Split('@')[0]</span>
                    <span class="user-role badge">
                        @if (User.IsInRole("Admin")) { <text>Admin</text> }
                        else if (User.IsInRole("Manager")) { <text>Manager</text> }
                        else { <text>Receptionist</text> }
                    </span>
                </div>
            </div>

            <ul class="sidebar-nav">
                <li class="nav-label">Main</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                    </a>
                </li>

                <li class="nav-label">Bookings</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")"
                       asp-controller="Booking" asp-action="Index">
                        <i class="bi bi-calendar-check"></i> <span>All Bookings</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Booking" asp-action="Create">
                        <i class="bi bi-plus-circle"></i> <span>New Booking</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Room" && ViewContext.RouteData.Values["action"]?.ToString() == "Availability" ? "active" : "")"
                       asp-controller="Room" asp-action="Availability">
                        <i class="bi bi-search"></i> <span>Room Availability</span>
                    </a>
                </li>

                <li class="nav-label">Management</li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Guest" ? "active" : "")"
                       asp-controller="Guest" asp-action="Index">
                        <i class="bi bi-people"></i> <span>Guests</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Room" && ViewContext.RouteData.Values["action"]?.ToString() != "Availability" ? "active" : "")"
                       asp-controller="Room" asp-action="Index">
                        <i class="bi bi-door-open"></i> <span>Rooms</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")"
                       asp-controller="Invoice" asp-action="Index">
                        <i class="bi bi-receipt"></i> <span>Invoices</span>
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-label">Administration</li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                           asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-person-gear"></i> <span>User Management</span>
                        </a>
                    </li>
                }
            </ul>

            <div class="sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-left"></i> <span>Logout</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <header class="topbar">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-right">
                    <span class="today-date"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dddd, MMMM dd yyyy")</span>
                </div>
            </header>

            <div class="content-area">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
