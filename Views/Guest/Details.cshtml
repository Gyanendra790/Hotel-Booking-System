@model Guest
@{
    ViewData["Title"] = "Guest Details";
}

<div class="page-header">
    <h4><i class="bi bi-person-circle me-2 text-primary"></i>@Model.FullName</h4>
    <div class="page-header-actions">
        <a asp-action="Edit" asp-route-id="@Model.GuestId" class="btn btn-outline-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="form-section mb-3">
            <div class="form-section-header"><i class="bi bi-person text-primary"></i> Profile</div>
            <div class="form-section-body">
                <div class="text-center mb-3">
                    <div style="width:72px;height:72px;background:var(--sidebar-active-bg);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:32px;color:var(--primary)">
                        <i class="bi bi-person"></i>
                    </div>
                    <div class="fw-800 fs-5 mt-2">@Model.FullName</div>
                </div>
                <div class="row g-2 small">
                    <div class="col-5 text-muted">Email</div><div class="col-7 fw-600">@Model.Email</div>
                    <div class="col-5 text-muted">Phone</div><div class="col-7 fw-600">@(Model.Phone ?? "—")</div>
                    <div class="col-5 text-muted">City</div><div class="col-7">@(Model.City ?? "—")</div>
                    <div class="col-5 text-muted">Country</div><div class="col-7">@(Model.Country ?? "—")</div>
                    <div class="col-5 text-muted">Date of Birth</div><div class="col-7">@(Model.DateOfBirth?.ToString("MM/dd/yyyy") ?? "—")</div>
                    <div class="col-5 text-muted">ID Type</div><div class="col-7">@Model.IdType</div>
                    <div class="col-5 text-muted">ID Number</div><div class="col-7">@(Model.IdNumber ?? "—")</div>
                    <div class="col-5 text-muted">Registered</div><div class="col-7 small">@Model.CreatedAt.ToString("MM/dd/yyyy")</div>
                </div>
            </div>
        </div>

        <div class="d-grid">
            <a asp-controller="Booking" asp-action="Create" asp-route-guestId="@Model.GuestId" class="btn btn-success">
                <i class="bi bi-calendar-plus me-2"></i>New Booking for Guest
            </a>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="section-card">
            <div class="section-card-header">
                <h6><i class="bi bi-calendar-check text-primary"></i> Booking History</h6>
                <span class="badge bg-primary">@Model.Bookings.Count booking(s)</span>
            </div>
            <div class="section-card-body">
                <table class="table-hotel w-100">
                    <thead>
                        <tr><th>Ref #</th><th>Room</th><th>Check-in</th><th>Check-out</th><th>Amount</th><th>Status</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var b in Model.Bookings.OrderByDescending(x => x.CreatedAt))
                    {
                        <tr>
                            <td><span class="fw-600 text-primary">@b.BookingReference</span></td>
                            <td>@b.Room.RoomNumber (@b.Room.RoomType)</td>
                            <td>@b.CheckInDate.ToString("MM/dd/yy")</td>
                            <td>@b.CheckOutDate.ToString("MM/dd/yy")</td>
                            <td class="fw-600">$@b.TotalAmount.ToString("N2")</td>
                            <td><span class="badge-status badge-@b.Status.ToString().ToLower()">@b.Status</span></td>
                            <td>
                                <a asp-controller="Booking" asp-action="Details" asp-route-id="@b.BookingId"
                                   class="btn btn-sm btn-outline-primary btn-icon">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Bookings.Any())
                    {
                        <tr><td colspan="7" class="no-results"><i class="bi bi-calendar-x d-block mb-2"></i>No bookings yet</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
