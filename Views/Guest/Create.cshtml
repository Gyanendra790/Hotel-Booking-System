@model Guest
@{
    bool isEdit = Model.GuestId > 0;
    ViewData["Title"] = isEdit ? "Edit Guest" : "Add Guest";
}

<div class="page-header">
    <h4><i class="bi bi-person-plus me-2 text-primary"></i>@ViewData["Title"]</h4>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-9">
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            @Html.AntiForgeryToken()

            <div class="form-section mb-3">
                <div class="form-section-header"><i class="bi bi-person text-primary"></i> Personal Information</div>
                <div class="form-section-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control" placeholder="John" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="LastName" class="form-control" placeholder="Smith" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Phone <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" placeholder="+1 555 000 0000" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IdType" class="form-label">ID Type</label>
                            <select asp-for="IdType" asp-items="Html.GetEnumSelectList<IdType>()" class="form-select"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="IdNumber" class="form-label">ID Number</label>
                            <input asp-for="IdNumber" class="form-control" placeholder="Passport / ID number" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section mb-3">
                <div class="form-section-header"><i class="bi bi-geo-alt text-primary"></i> Address</div>
                <div class="form-section-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">Street Address</label>
                            <input asp-for="Address" class="form-control" placeholder="123 Main St" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="City" class="form-label">City</label>
                            <input asp-for="City" class="form-control" placeholder="New York" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label">Country</label>
                            <input asp-for="Country" class="form-control" placeholder="United States" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>@(isEdit ? "Save Changes" : "Add Guest")</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
